# Set these in your shell or user environment. The CLI reads process.env directly.
FRONTEND_AUTOPILOT_API_KEY=sk-your-key
FRONTEND_AUTOPILOT_BASE_URL=https://api.openai.com/v1
FRONTEND_AUTOPILOT_MODEL=gpt-4o-mini
# Optional: only for gateways that enforce an approved client identifier.
# FRONTEND_AUTOPILOT_USER_AGENT=approved-client/1.0
FRONTEND_AUTOPILOT_MAX_RETRIES=6
FRONTEND_AUTOPILOT_REQUEST_TIMEOUT_MS=120000
FRONTEND_AUTOPILOT_STREAM_TIMEOUT_MS=600000
