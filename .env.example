# Set these in your shell or user environment. The CLI reads process.env directly.
VIBE_ONE_API_KEY=sk-your-key
VIBE_ONE_BASE_URL=https://api.openai.com/v1
VIBE_ONE_MODEL=gpt-4o-mini
# Optional: only for gateways that enforce an approved client identifier.
# VIBE_ONE_USER_AGENT=approved-client/1.0
VIBE_ONE_MAX_RETRIES=6
VIBE_ONE_REQUEST_TIMEOUT_MS=120000
VIBE_ONE_STREAM_TIMEOUT_MS=600000
